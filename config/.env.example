# AI Content Agent - Environment Configuration
# Copy this file to .env and fill in your values

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# GitHub
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Email (optional)
EMAIL_API_KEY=your-email-api-key

# LinkedIn (optional)
LINKEDIN_API_KEY=your-linkedin-api-key

# Instagram (optional)
INSTAGRAM_API_KEY=your-instagram-api-key

# AI Provider (openai, anthropic, local)
AI_PROVIDER=openai
AI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
AI_MODEL=gpt-4o-mini
# AI_BASE_URL=https://your-api-endpoint.com/v1

# Dashboard
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=5000
DASHBOARD_SECRET_KEY=change-this-to-a-random-secret

# Scheduling
CHECK_INTERVAL_MINUTES=15
